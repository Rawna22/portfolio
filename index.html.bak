<!-- ===== PROJECTS ===== -->
<section class="section" id="projects">
  <div class="section-head">
    <span class="section-num">01</span>
    <h2 class="section-title">Featured Projects</h2>
  </div>
  <p class="section-desc">Things I've built — from infrastructure tools to automation frameworks.</p>

  <div class="projects-grid">

    <a href="https://github.com/Rawna22/proxy-setup-cli" target="_blank" class="project-card">
      <div class="project-icon">🚀</div>
      <div class="project-body">
        <div class="project-top">
          <h3>Proxy Setup CLI</h3>
          <span class="project-link">↗</span>
        </div>
        <p>One-command proxy server deployment. VLESS, Trojan, Shadowsocks with auto SSL.</p>
        <div class="project-tags">
          <span>Bash</span><span>Xray</span><span>Let's Encrypt</span>
        </div>
      </div>
    </a>

    <a href="https://github.com/Rawna22/docker-stacks" target="_blank" class="project-card">
      <div class="project-icon">🐳</div>
      <div class="project-body">
        <div class="project-top">
          <h3>Docker Stacks</h3>
          <span class="project-link">↗</span>
        </div>
        <p>Production-ready compose stacks — monitoring, media, dev, networking.</p>
        <div class="project-tags">
          <span>Docker</span><span>Grafana</span><span>DevOps</span>
        </div>
      </div>
    </a>

    <a href="https://github.com/Rawna22/wallet-tracker" target="_blank" class="project-card">
      <div class="project-icon">💰</div>
      <div class="project-body">
        <div class="project-top">
          <h3>Wallet Tracker</h3>
          <span class="project-link">↗</span>
        </div>
        <p>Multi-chain crypto wallet portfolio tracker with real-time balance updates.</p>
        <div class="project-tags">
          <span>Python</span><span>Solana</span><span>BSC</span>
        </div>
      </div>
    </a>

    <a href="https://github.com/Rawna22" target="_blank" class="project-card">
      <div class="project-icon">⚡</div>
      <div class="project-body">
        <div class="project-top">
          <h3>AI Gateway</h3>
          <span class="project-link">↗</span>
        </div>
        <p>Multi-provider LLM proxy with load balancing, failover, and rate limiting.</p>
        <div class="project-tags">
          <span>Node.js</span><span>Redis</span><span>API</span>
        </div>
      </div>
    </a>

