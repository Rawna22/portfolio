<!-- ===== HERO ===== -->
<header class="hero" id="home">
  <div class="hero-bg"></div>
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <p class="hero-status"><span class="status-dot"></span> Available for work</p>
    <h1 class="hero-title">
      I build <span class="highlight">infra</span> &amp;<br>
      <span class="highlight">automation</span> systems
    </h1>
    <p class="hero-sub">
      Backend developer from Indonesia 🇮🇩 — focused on proxy infrastructure, bot frameworks, and scalable cloud systems.
    </p>
    <div class="hero-cta">
      <a href="#projects" class="btn btn-primary">See Projects ↓</a>
      <a href="#contact" class="btn btn-ghost">Contact Me</a>
    </div>
    <div class="hero-stats">
      <div><strong>3+</strong><span>Years Exp</span></div>
      <div><strong>12+</strong><span>Projects</span></div>
      <div><strong>99%</strong><span>Uptime</span></div>
    </div>
  </div>
