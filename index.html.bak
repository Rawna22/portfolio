<!-- ===== CONTACT ===== -->
<section class="section contact-section" id="contact">
  <div class="section-head">
    <span class="section-num">04</span>
    <h2 class="section-title">Get in Touch</h2>
  </div>
  <p class="section-desc">Have a project in mind? Let's talk.</p>

  <div class="contact-grid">
    <form class="contact-form" id="contactForm" action="https://formspree.io/f/your-form-id" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" placeholder="Your name" required>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@email.com" required>
        </div>
      </div>
      <div class="form-group">
        <label for="subject">Subject</label>
        <input type="text" id="subject" name="subject" placeholder="Project / Job / Question">
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="4" placeholder="Tell me about your project..." required></textarea>
      </div>
      <button type="submit" class="btn btn-primary" id="submitBtn">Send Message →</button>
      <p class="form-success" id="formSuccess">✅ Message sent! I'll reply within 24 hours.</p>
    </form>

    <div class="contact-info">
      <a href="https://t.me/Rawna22" target="_blank" class="contact-card">
        <span class="contact-emoji">✈️</span>
        <div>
          <h4>Telegram</h4>
          <p>@Rawna22 — fastest response</p>
        </div>
      </a>
      <a href="mailto:hello@rawna.dev" class="contact-card">
        <span class="contact-emoji">📧</span>
        <div>
          <h4>Email</h4>
          <p>hello@rawna.dev</p>
        </div>
      </a>
      <a href="https://github.com/Rawna22" target="_blank" class="contact-card">
        <span class="contact-emoji">🐙</span>
        <div>
          <h4>GitHub</h4>
          <p>@Rawna22 — see my repos</p>
        </div>
      </a>
      <div class="contact-card">
        <span class="contact-emoji">📍</span>
        <div>
          <h4>Location</h4>
          <p>Indonesia — remote worldwide</p>
        </div>
      </div>
    </div>
  </div>
</section>

